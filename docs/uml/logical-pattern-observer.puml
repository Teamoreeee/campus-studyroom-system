@startuml logical-pattern-observer
!theme plain
skinparam backgroundColor #FEFEFE
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classFontName Microsoft YaHei
skinparam defaultFontName Microsoft YaHei
skinparam shadowing false

title 校园自习室预约系统 - 观察者模式详细类图（逻辑视图）

' ============================================================
' 设计说明：
' 本图展示校园自习室预约系统中观察者模式（Observer Pattern）
' 的详细设计。观察者模式是行为型设计模式的核心模式，在本
' 系统中用于预约事件的通知和处理。
'
' 设计背景：
' 在自习室预约系统中，预约状态的变化会引发多个后续操作：
' 预约创建后需要初始化考勤记录、发送通知给用户、检查用户
' 违规记录；预约取消后需要释放座位资源、通知用户取消确认、
' 更新AI推荐数据；预约完成后需要记录考勤信息、检查违规、
' 更新用户行为数据。如果将这些操作硬编码在预约服务中，将
' 导致预约服务与多个下游服务紧耦合，代码难以维护和扩展。
'
' 设计方案：
' 采用观察者模式，定义ReservationEventPublisher事件发布者
' 和ReservationEventListener事件监听者接口。当预约状态发生
' 变化时，发布者通知所有注册的监听者，各监听者独立处理各自
' 的业务逻辑。结合Spring Event机制和RabbitMQ实现事件的
' 同步/异步处理，确保系统解耦和可靠性。
'
' 核心类说明：
' - ReservationEventPublisher：事件发布者，维护监听者列表，
'   提供事件发布和监听者注册/注销方法
' - ReservationEventListener：事件监听者接口，定义事件回调方法
' - AttendanceListener：考勤监听器，处理考勤记录的创建和更新
' - NotificationListener：通知监听器，处理各类通知的发送
' - ViolationListener：违规监听器，检查和处理违规行为
' - AIAnalysisListener：AI分析监听器，更新用户行为数据和推荐
'
' 事件类型：
' - ReservationCreatedEvent：预约创建事件
' - ReservationCancelledEvent：预约取消事件
' - ReservationCompletedEvent：预约完成事件
' - ReservationCheckedInEvent：签到事件
' - ReservationNoShowEvent：爽约事件
'
' 与Spring集成：
' 利用Spring的ApplicationEvent和@EventListener注解实现
' 同步事件处理，结合@Async注解实现异步事件处理，同时
' 通过RabbitMQ实现跨服务的事件消息传递。
' ============================================================

package "观察者模式 - 预约事件系统" #FFFDE7 {

    package "事件定义 (Events)" #E8F5E9 {
        abstract class ReservationEvent {
            # eventId: String
            # eventType: ReservationEventType
            # reservationId: Long
            - userId: Long
            - seatId: Long
            - roomId: Long
            - timestamp: LocalDateTime
            - source: String
            + getEventId(): String
            + getEventType(): ReservationEventType
            + getTimestamp(): LocalDateTime
            + getSource(): String
            + toMessage(): String
            + getHeaders(): Map<String, Object>
        }

        enum ReservationEventType {
            CREATED
            CANCELLED
            COMPLETED
            CHECKED_IN
            CHECKED_OUT
            NO_SHOW
            EXPIRED
        }

        class ReservationCreatedEvent {
            - reserveDate: LocalDate
            - startTime: LocalTime
            - endTime: LocalTime
            - seatNo: String
            - roomName: String
            + getReserveDate(): LocalDate
            + getTimeRange(): String
            + getSeatInfo(): String
        }

        class ReservationCancelledEvent {
            - cancelReason: String
            - cancelTime: LocalDateTime
            - refundStatus: Boolean
            + getCancelReason(): String
            + isRefundable(): Boolean
        }

        class ReservationCompletedEvent {
            - actualStartTime: LocalDateTime
            - actualEndTime: LocalDateTime
            - duration: Integer
            - rating: Integer
            + getActualDuration(): Integer
            + getRating(): Integer
        }

        class ReservationCheckedInEvent {
            - checkInTime: LocalDateTime
            - checkInMethod: CheckInMethod
            - isLate: Boolean
            - lateMinutes: Integer
            + getCheckInTime(): LocalDateTime
            + isLateCheckIn(): Boolean
        }

        class ReservationNoShowEvent {
            - expectedTime: LocalDateTime
            - consecutiveNoShows: Integer
            - shouldSuspend: Boolean
            + getConsecutiveNoShows(): Integer
            + shouldSuspendUser(): Boolean
        }

        ReservationEvent <|-- ReservationCreatedEvent
        ReservationEvent <|-- ReservationCancelledEvent
        ReservationEvent <|-- ReservationCompletedEvent
        ReservationEvent <|-- ReservationCheckedInEvent
        ReservationEvent <|-- ReservationNoShowEvent
        ReservationEvent --> ReservationEventType
    }

    package "事件发布者 (Publisher)" #E3F2FD {
        class ReservationEventPublisher {
            - listeners: List<ReservationEventListener>
            - asyncExecutor: AsyncTaskExecutor
            - rabbitTemplate: RabbitTemplate
            - eventStore: EventStore
            - objectMapper: ObjectMapper
            - eventQueue: String

            + publishEvent(event: ReservationEvent): void
            + publishEventAsync(event: ReservationEvent): void
            + publishToMQ(event: ReservationEvent): void
            + addListener(listener: ReservationEventListener): void
            + removeListener(listener: ReservationEventListener): void
            + removeAllListeners(): void
            + getListenerCount(): Integer
            + getListeners(): List<ReservationEventListener>
            - notifyListeners(event: ReservationEvent): void
            - notifyListener(listener: ReservationEventListener, event: ReservationEvent): void
            - storeEvent(event: ReservationEvent): void
            - handleListenerException(e: Exception, listener: ReservationEventListener): void
        }

        class EventStore {
            - eventRepository: EventRepository
            + store(event: ReservationEvent): void
            + getEvents(reservationId: Long): List<ReservationEvent>
            + getEventsByType(type: ReservationEventType): List<ReservationEvent>
            + getEventsByTimeRange(start: LocalDateTime, end: LocalDateTime): List<ReservationEvent>
            + replayEvents(reservationId: Long): void
        }

        ReservationEventPublisher --> ReservationEventListener : 通知
        ReservationEventPublisher --> EventStore
        ReservationEventPublisher ..> ReservationEvent : 发布
    }

    package "事件监听者接口 (Listener Interface)" #FFF3E0 {
        interface ReservationEventListener {
            + onReservationCreated(event: ReservationCreatedEvent): void
            + onReservationCancelled(event: ReservationCancelledEvent): void
            + onReservationCompleted(event: ReservationCompletedEvent): void
            + onReservationCheckedIn(event: ReservationCheckedInEvent): void
            + onReservationNoShow(event: ReservationNoShowEvent): void
            + getOrder(): Integer
            + isAsync(): Boolean
            + supports(eventType: ReservationEventType): Boolean
        }
    }

    package "考勤监听器 (Attendance Listener)" #F3E5F5 {
        class AttendanceListener {
            - attendanceService: AttendanceService
            - checkInConfig: CheckInConfig
            - timeSlotService: TimeSlotService

            + onReservationCreated(event: ReservationCreatedEvent): void
            + onReservationCancelled(event: ReservationCancelledEvent): void
            + onReservationCompleted(event: ReservationCompletedEvent): void
            + onReservationCheckedIn(event: ReservationCheckedInEvent): void
            + onReservationNoShow(event: ReservationNoShowEvent): void
            + getOrder(): Integer
            + isAsync(): Boolean
            + supports(eventType: ReservationEventType): Boolean
            - createAttendanceRecord(event: ReservationCreatedEvent): void
            - updateAttendanceOnCheckIn(event: ReservationCheckedInEvent): void
            - recordCompletion(event: ReservationCompletedEvent): void
            - markAsAbsent(event: ReservationNoShowEvent): void
            - releaseSeatOnCancel(event: ReservationCancelledEvent): void
        }

        class CheckInConfig {
            - lateThresholdMinutes: Integer
            - autoCheckOutEnabled: Boolean
            - noShowThresholdMinutes: Integer
            + isLate(checkInTime: LocalDateTime, expectedTime: LocalDateTime): Boolean
            + isNoShow(checkInTime: LocalDateTime, expectedTime: LocalDateTime): Boolean
        }

        AttendanceListener --> CheckInConfig
        ReservationEventListener <|.. AttendanceListener
    }

    package "通知监听器 (Notification Listener)" #FCE4EC {
        class NotificationListener {
            - notificationService: NotificationService
            - notificationFactoryProducer: NotificationFactoryProducer
            - templateService: TemplateService
            - userPreferenceService: UserPreferenceService

            + onReservationCreated(event: ReservationCreatedEvent): void
            + onReservationCancelled(event: ReservationCancelledEvent): void
            + onReservationCompleted(event: ReservationCompletedEvent): void
            + onReservationCheckedIn(event: ReservationCheckedInEvent): void
            + onReservationNoShow(event: ReservationNoShowEvent): void
            + getOrder(): Integer
            + isAsync(): Boolean
            + supports(eventType: ReservationEventType): Boolean
            - sendReservationConfirmation(event: ReservationCreatedEvent): void
            - sendCancellationNotice(event: ReservationCancelledEvent): void
            - sendCompletionSummary(event: ReservationCompletedEvent): void
            - sendCheckInReminder(event: ReservationCheckedInEvent): void
            - sendNoShowWarning(event: ReservationNoShowEvent): void
            - getUserNotificationPreference(userId: Long): NotificationPreference
            - buildNotificationContent(template: String, event: ReservationEvent): String
        }

        class NotificationPreference {
            - userId: Long
            - emailEnabled: Boolean
            - smsEnabled: Boolean
            - inAppEnabled: Boolean
            - quietHoursStart: LocalTime
            - quietHoursEnd: LocalTime
            + isQuietHours(): Boolean
            + getEnabledChannels(): List<NotificationType>
        }

        NotificationListener --> NotificationPreference
        ReservationEventListener <|.. NotificationListener
    }

    package "违规监听器 (Violation Listener)" #E0F7FA {
        class ViolationListener {
            - violationService: ViolationService
            - penaltyPolicy: PenaltyPolicy
            - userBehaviorService: UserBehaviorService

            + onReservationCreated(event: ReservationCreatedEvent): void
            + onReservationCancelled(event: ReservationCancelledEvent): void
            + onReservationCompleted(event: ReservationCompletedEvent): void
            + onReservationCheckedIn(event: ReservationCheckedInEvent): void
            + onReservationNoShow(event: ReservationNoShowEvent): void
            + getOrder(): Integer
            + isAsync(): Boolean
            + supports(eventType: ReservationEventType): Boolean
            - checkForViolation(event: ReservationEvent): void
            - recordViolation(userId: Long, type: ViolationType, event: ReservationEvent): void
            - applyPenalty(violation: Violation): void
            - checkConsecutiveNoShows(userId: Long): Integer
            - shouldSuspendUser(userId: Long): Boolean
            - suspendUser(userId: Long, days: Integer): void
            - updateBehaviorScore(userId: Long, delta: Integer): void
        }

        class PenaltyPolicy {
            - noShowPenaltyDays: Integer
            - lateCheckInPenaltyDays: Integer
            - earlyLeavePenaltyDays: Integer
            - consecutiveNoShowThreshold: Integer
            - maxPenaltyDays: Integer
            + calculatePenalty(type: ViolationType, count: Integer): Integer
            + shouldSuspend(consecutiveNoShows: Integer): Boolean
            + getSuspensionDays(consecutiveNoShows: Integer): Integer
        }

        ViolationListener --> PenaltyPolicy
        ReservationEventListener <|.. ViolationListener
    }

    package "AI分析监听器 (AI Analysis Listener)" #FFF9C4 {
        class AIAnalysisListener {
            - userBehaviorService: UserBehaviorService
            - recommendService: RecommendService
            - anomalyDetectionService: AnomalyDetectionService
            - behaviorAnalyzer: BehaviorAnalyzer

            + onReservationCreated(event: ReservationCreatedEvent): void
            + onReservationCancelled(event: ReservationCancelledEvent): void
            + onReservationCompleted(event: ReservationCompletedEvent): void
            + onReservationCheckedIn(event: ReservationCheckedInEvent): void
            + onReservationNoShow(event: ReservationNoShowEvent): void
            + getOrder(): Integer
            + isAsync(): Boolean
            + supports(eventType: ReservationEventType): Boolean
            - recordBehavior(event: ReservationEvent): void
            - updateUserPreferenceModel(userId: Long): void
            - detectAnomaly(event: ReservationEvent): void
            - triggerModelRetraining(): void
            - updateRecommendationCache(userId: Long): void
            - analyzeBehaviorPattern(userId: Long): BehaviorPattern
        }

        class BehaviorAnalyzer {
            - patternDetector: PatternDetector
            - featureExtractor: FeatureExtractor
            + analyze(userId: Long, behaviors: List): BehaviorPattern
            + detectAnomalies(pattern: BehaviorPattern): List<Anomaly>
            + extractFeatures(behavior: UserBehavior): FeatureVector
        }

        class BehaviorPattern {
            - userId: Long
            - avgDuration: Double
            - preferredTimeSlots: List<TimeSlot>
            - preferredRooms: List<Long>
            - noShowRate: Double
            - cancellationRate: Double
            + isNormal(): Boolean
            + getAnomalyScore(): Double
        }

        AIAnalysisListener --> BehaviorAnalyzer
        BehaviorAnalyzer ..> BehaviorPattern
        ReservationEventListener <|.. AIAnalysisListener
    }
}

package "Spring事件集成" #E8EAF6 {
    class ReservationSpringEvent {
        - sourceEvent: ReservationEvent
        + getSourceEvent(): ReservationEvent
    }

    class ReservationEventConfig {
        - asyncExecutor: AsyncTaskExecutor
        - rabbitMQConfig: RabbitMQConfig
        + applicationEventPublisher(): ApplicationEventPublisher
        + asyncEventListenerExecutor(): AsyncTaskExecutor
    }

    note "Spring @EventListener 注解\n实现同步事件处理\n@Async + @EventListener\n实现异步事件处理\nRabbitMQ消息广播\n实现跨服务事件传递" as SpringIntegration
}

ReservationEventPublisher --> ReservationSpringEvent : 包装
ReservationEventPublisher ..> ReservationEventConfig : 配置

note right of ReservationEventPublisher
  事件发布者是观察者模式的核心，
  维护所有监听器的注册列表。
  事件发布采用三级策略：
  1. 同步通知：关键事件即时处理
  2. 异步通知：通过线程池异步处理
  3. MQ广播：跨服务事件传递
  支持事件持久化和重放机制
end note

note left of AIAnalysisListener
  AI分析监听器处理最复杂，
  执行行为记录、异常检测、
  推荐更新等多步操作。
  设置为异步执行(order=4)，
  不阻塞其他监听器处理。
end note

@enduml
