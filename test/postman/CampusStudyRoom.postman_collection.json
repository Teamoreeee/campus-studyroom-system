    {
      "name": "认证模块",
      "item": [
        {
          "name": "用户登录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"testuser2026\", \"password\": \"Test@1234\"}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"状态码 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"返回 accessToken\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.accessToken).to.exist;",
                  "    pm.environment.set(\"access_token\", json.data.accessToken);",
                  "    pm.environment.set(\"refresh_token\", json.data.refreshToken);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "获取当前用户信息",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/profile",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "profile"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"状态码 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"返回用户信息\", () => {",
                  "    pm.expect(pm.response.json().data).to.have.property(\"userId\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
